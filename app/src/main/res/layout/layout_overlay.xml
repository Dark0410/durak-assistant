<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_overlay"
    android:elevation="8dp"
    android:orientation="vertical"
    android:padding="16dp"
    android:minWidth="200dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        
        <TextView
            android:id="@+id/tvLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="СОВЕТ ИИ"
            android:textColor="@color/accent_blue"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.1" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchAi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:checked="false"
            android:thumbTint="@color/white"
            tools:ignore="UseSwitchCompatOrMaterialXml" />
    </RelativeLayout>

    <TextView
        android:id="@+id/tvAdvice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Анализирую ситуацию..."
        android:textColor="@color/white"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:lineSpacingExtra="2dp" />

    <!-- Button to mark current table cards as GONE (Bito) -->
    <Button
        android:id="@+id/btnMarkBito"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_marginTop="12dp"
        android:backgroundTint="#4CAF50"
        android:text="БИТО (В СБРОС)"
        android:textColor="@color/white"
        android:textSize="10sp"
        android:padding="0dp"
        android:insetTop="0dp"
        android:insetBottom="0dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:background="@color/glass_stroke" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvCardsLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="В колоде: ?"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_preferences"
            android:contentDescription="Настройки"
            android:tint="@color/white" />
    </RelativeLayout>
</LinearLayout>
